# ─────────────────────────────────────────────────────────────────
# NetFabric — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# JWT token expiry in minutes (default 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Encryption ────────────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-with-fernet

# ── AI (optional) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=netfabric
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=netfabric
DATABASE_URL=postgresql://netfabric:change-me-strong-password@db:5432/netfabric
